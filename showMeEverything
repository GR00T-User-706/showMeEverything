#!/usr/bin/env bash
header0() {
    echo "#=========================================================#"
    echo "$1"
    echo "#=========================================================#"
}

footer() {
    local TODAY="$(date +%c)"
    local info="$(echo "${TODAY} ${SHELL} ${USER} ${HOST}")"
    header0 "$info"
}

if [ -n "${ZSH_VERSION:-}" ]; then
    current_shell="zsh"
elif [ -n "${BASH_VERSION:-}" ]; then
    current_shell="bash"
else
    current_shell="$(basename "$SHELL")"
fi

[ "$current_shell" = "bash" ] && shopt -s expand_aliases 2>/dev/null

#==========================================#
#==== SHELL SPECIFIC  SEARCH FUNCTIONS ====#
#==========================================#
search_path() {
    local info="Searching \$PATH for $1..."
    local dir
    header0 "$info"

    IFS=':'
    for dir in $PATH; do
        [ -d "$dir" ] || continue
        find "$dir" -not -path "$HOME/.cache/*" -iname "*$1*" 2>/dev/null
    done
    unset IFS
}

search_loaded_commands() {
    local info="Searching loaded shell commands for $1..."
    header0 "$info"

    if [ "$current_shell" = "zsh" ]; then
        eval 'print -rl -- ${(k)commands}' | grep -i -- "$1"
    elif [ "$current_shell" = "bash" ]; then
        compgen -c | grep -i -- "$1"
    fi
}

search_builtins() {
    local info="Searching shell builtins for $1..."
    header0 "$info"

    if [ "$current_shell" = "zsh" ]; then
        eval 'print -rl -- ${(k)builtins}' | grep -i -- "$1"
    elif [ "$current_shell" = "bash" ]; then
        compgen -b | grep -i -- "$1"
    fi
}

search_shell_functions() {
    local info="Searching loaded shell functions for $1..."
    header0 "$info"

    if [ "$current_shell" = "zsh" ]; then
        eval 'print -rl -- ${(k)functions}' | grep -i -- "$1"
    elif [ "$current_shell" = "bash" ]; then
        compgen -A function | grep -i -- "$1"
    fi
}

search_aliases() {
    local info="Searching shell aliases for $1..."
    header0 "$info"
    alias | grep -i -- "$1"
}

{
    #===============================#
    #===PACKAGE MANAGER DETECTION===#
    #===============================#
    {
        get_package_manager() {
            if command -v pacman >/dev/null 2>&1; then
                echo "pacman"
            elif command -v apt-cache >/dev/null 2>&1 && command -v dpkg-query >/dev/null 2>&1; then
                echo "apt"
            elif command -v dnf >/dev/null 2>&1; then
                echo "dnf"
            elif command -v zypper >/dev/null 2>&1; then
                echo "zypper"
            elif command -v apk >/dev/null 2>&1; then
                echo "apk"
            fi
        }
    }

    {
        #===============================#
        #=======PACMAN FUNCTIONS========#
        #===============================#
        {
            # -------- full repo ---------- #
            pacman_full_repo_search() {
                local info="Searching Pacman repo for $1..."
                header0 "$info"
                pacman -Sl 2>/dev/null | grep -i -- "$1"
            }

            # -------- installed ---------- #
            pacman_installed_packages_search() {
                local info="Searching installed Pacman packages for $1..."
                header0 "$info"
                pacman -Q 2>/dev/null | grep -i -- "$1"
            }

            #--------not installed----------#
            pacman_search_not_installed() {
                local info="Searching Pacman for packages not installed: $1..."
                header0 "$info"
                comm -23 \
                    <(pacman -Slq 2>/dev/null | grep -i -- "$1" | sort -u) \
                    <(pacman -Qq 2>/dev/null | sort -u)
            }

            # --------- files DB ---------- #
            pacman_files_db_search() {
                local info="Searching Pacman file database for $1..."
                header0 "$info"
                pacman -F "$1" 2>/dev/null
            }
        }
    }

    {
        #===============================#
        #=========APT FUNCTIONS=========#
        #===============================#
        {
            # -------- full repo ---------- #
            apt_full_repo_search() {
                local info="Searching APT repo for $1..."
                header0 "$info"
                if [ -z "$1" ]; then
                    apt list 2>/dev/null
                else
                    apt list 2>/dev/null | grep -i -- "$1"
                fi
            }

            # -------- installed ---------- #
            apt_installed_packages_search() {
                local info="Searching installed APT packages for $1..."
                header0 "$info"
                dpkg-query -W 2>/dev/null | grep -i -- "$1"
            }

            #--------not installed----------#
            apt_search_not_installed() {
                local info="Searching APT for packages not installed: $1..."
                header0 "$info"
                comm -23 \
                    <(apt-cache pkgnames 2>/dev/null | grep -i -- "$1" | sort -u) \
                    <(dpkg-query -W -f='${binary:Package}\n' 2>/dev/null | sort -u)
            }

            # --------- files DB ---------- #
            apt_files_db_search() {
                local info="Searching installed APT/DPKG file ownership for $1..."
                header0 "$info"
                dpkg -S "*$1*" 2>/dev/null
            }
        }
    }

    {
        #===============================#
        #=========DNF FUNCTIONS=========#
        #===============================#
        {
            # -------- full repo ---------- #
            dnf_full_repo_search() {
                local info="Searching DNF repo for $1..."
                header0 "$info"
                dnf list available 2>/dev/null | grep -i -- "$1"
            }

            # -------- installed ---------- #
            dnf_installed_packages_search() {
                local info="Searching installed DNF packages for $1..."
                header0 "$info"
                dnf list installed 2>/dev/null | grep -i -- "$1"
            }

            #--------not installed----------#
            dnf_search_not_installed() {
                local info="Searching DNF for packages not installed: $1..."
                header0 "$info"
                comm -23 \
                    <(dnf list available 2>/dev/null | awk 'NR > 1 {print $1}' | sed 's/\.[^.[:space:]]*$//' | grep -i -- "$1" | sort -u) \
                    <(dnf list installed 2>/dev/null | awk 'NR > 1 {print $1}' | sed 's/\.[^.[:space:]]*$//' | sort -u)
            }

            # --------- files DB ---------- #
            dnf_files_db_search() {
                local info="Searching DNF/RPM file ownership for $1..."
                header0 "$info"
                repoquery -f "*$1*" 2>/dev/null
            }
        }
    }

    {
        #===============================#
        #=======ZYPPER FUNCTIONS========#
        #===============================#
        {
            # -------- full repo ---------- #
            zypper_full_repo_search() {
                local info="Searching Zypper repo for $1..."
                header0 "$info"
                zypper search 2>/dev/null | grep -i -- "$1"
            }

            # -------- installed ---------- #
            zypper_installed_packages_search() {
                local info="Searching installed Zypper packages for $1..."
                header0 "$info"
                rpm -qa --qf '%{NAME} %{VERSION}-%{RELEASE}\n' 2>/dev/null | grep -i -- "$1"
            }

            #--------not installed----------#
            zypper_search_not_installed() {
                local info="Searching Zypper for packages not installed: $1..."
                header0 "$info"
                comm -23 \
                    <(zypper search 2>/dev/null | awk 'NR > 4 {print $3}' | grep -i -- "$1" | sort -u) \
                    <(rpm -qa --qf '%{NAME}\n' 2>/dev/null | sort -u)
            }

            # --------- files DB ---------- #
            zypper_files_db_search() {
                local info="Searching Zypper/RPM file ownership for $1..."
                header0 "$info"
                rpm -qal 2>/dev/null | grep -i -- "$1"
            }
        }
    }

    {
        #===============================#
        #=========APK FUNCTIONS=========#
        #===============================#
        {
            # -------- full repo ---------- #
            apk_full_repo_search() {
                local info="Searching APK repo for $1..."
                header0 "$info"
                apk search 2>/dev/null | grep -i -- "$1"
            }

            # -------- installed ---------- #
            apk_installed_packages_search() {
                local info="Searching installed APK packages for $1..."
                header0 "$info"
                apk info 2>/dev/null | grep -i -- "$1"
            }

            #--------not installed----------#
            apk_search_not_installed() {
                local info="Searching APK for packages not installed: $1..."
                header0 "$info"
                comm -23 \
                    <(apk search 2>/dev/null | sed 's/-[0-9].*$//' | grep -i -- "$1" | sort -u) \
                    <(apk info 2>/dev/null | sort -u)
            }

            # --------- files DB ---------- #
            apk_files_db_search() {
                local info="Searching APK file ownership for $1..."
                header0 "$info"
                apk info -L 2>/dev/null | grep -i -- "$1"
            }
        }
    }

    {
        #===============================#
        #== PACKAGE MANAGER MANAGMENT ==#
        #===============================#
        {
            #  ---- FULL REPO  ------ #
            search_package_repo() {
                case "$(get_package_manager)" in
                pacman) pacman_full_repo_search "$1" ;;
                apt) apt_full_repo_search "$1" ;;
                dnf) dnf_full_repo_search "$1" ;;
                zypper) zypper_full_repo_search "$1" ;;
                apk) apk_full_repo_search "$1" ;;
                esac
            }

            # ----- NOT INSTALLED --- #
            search_packages_not_installed() {
                case "$(get_package_manager)" in
                pacman) pacman_search_not_installed "$1" ;;
                apt) apt_search_not_installed "$1" ;;
                dnf) dnf_search_not_installed "$1" ;;
                zypper) zypper_search_not_installed "$1" ;;
                apk) apk_search_not_installed "$1" ;;
                esac
            }

            # ------- INSTALLED ----- #
            search_installed_packages() {
                case "$(get_package_manager)" in
                pacman) pacman_installed_packages_search "$1" ;;
                apt) apt_installed_packages_search "$1" ;;
                dnf) dnf_installed_packages_search "$1" ;;
                zypper) zypper_installed_packages_search "$1" ;;
                apk) apk_installed_packages_search "$1" ;;
                esac
            }

            # --- pkg mngr file DB --- #
            search_package_files_db() {
                case "$(get_package_manager)" in
                pacman) pacman_files_db_search "$1" ;;
                apt) apt_files_db_search "$1" ;;
                dnf) dnf_files_db_search "$1" ;;
                zypper) zypper_files_db_search "$1" ;;
                apk) apk_files_db_search "$1" ;;
                esac
            }
        }
    }
}

search_manpages() {
    local info="Searching manpage descriptions for $1..."
    local wcs="*$1*"
    header0 "$info"

    if command -v apropos >/dev/null 2>&1; then
        apropos -w "$wcs" | grep -i -- "$1"
    fi
}

search_systemd_units() {
    local info="Searching systemd unit files for $1..."
    header0 "$info"

    if command -v systemctl >/dev/null 2>&1; then
        systemctl list-unit-files 2>/dev/null | grep -i -- "$1"
    fi
}

search_running_processes() {
    local info="Searching running processes for $1..."
    header0 "$info"
    ps aux 2>/dev/null | grep -i -- "$1"
}

loaded_kernel_modules() {
    local info="Searching loaded kernel modules for $1..."
    header0 "$info"

    if command -v lsmod >/dev/null 2>&1; then
        lsmod 2>/dev/null | grep -i -- "$1"
    fi
}

search_home_directory() {
    local info="Searching the home directory $HOME for $1..."
    header0 "$info"

    if [ -z "$1" ]; then
        find "$HOME"  2>/dev/null
    else
        find "$HOME"  -iname "*$1*" 2>/dev/null
    fi
}

search_system_dirs() {
    local info="Searching system directories (/usr, /etc, /sys, /var, /opt, /boot, /lib, /bin, /sbin) for $1..."
    local d
    header0 "$info"

    for d in /usr /etc /sys /var /opt /boot /lib /bin /sbin; do
        [ -d "$d" ] && find "$d" -iname "*$1*" 2>/dev/null
    done
}

help() {
    echo -e "

parameters are optional for every argument both long and short, however search requires at exactly 1 argument flag
it will treat a second argument as the search parameter and ignore anything after the second positional parameter
--all | -A <STRING>                        search commands, manpages, packages, and filesystem for <string> \n
--aliases | -a <STRING>                    search shell aliases for <STRING> \n
--builtins | -B <STRING>                   search shell builtins for <STRING> \n
--command | -c <STRING>                    search for <STRING> in loaded shell command list \n
--files | -F <STRING>                      search the detected package file database for <STRING> \n
--functions | -f <STRING>                  search loaded shell functions for <STRING> \n
--help | -h                                print this help message \n
--home | -H <STRING>                       search your \$HOME directory for <STRING> \n
--installed | -i <STRING>                  search installed packages for <STRING> \n
--modules | -m <STRING>                    search loaded kernel modules for <STRING> \n
--manpages | --man <STRING>                search manpage descriptions for <STRING> \n
--packages | -p | --pkg <STRING>           search the detected package manager database for <STRING> \n
--path | -P <STRING>                       search the shell's \$PATH for <STRING> \n
--process | -x <STRING>                    search running processes for <STRING> \n
--systemd | -s <STRING>                    search systemd unit files for <STRING> \n
--system | -R <STRING>                     search system directories (/usr, /etc, /sys, ...) for <STRING> \n
Note: each search module prints a header and raw results; no lines are filtered or removed beyond explicit search arguments and hidden stderr."
} # currently 16 --help flag lines meaning 33 total flags long and short

search() {
    local pattern=""
    local -a actions=()
    local use_less=false

    while [ $# -gt 0 ]; do
        case "$1" in
            --less) use_less=true ;;
            --all | -A)
                actions+=(
                    search_path
                    search_loaded_commands
                    search_builtins
                    search_aliases
                    search_shell_functions
                    search_manpages
                    search_systemd_units
                    search_running_processes
                    loaded_kernel_modules
                    search_package_repo
                    search_installed_packages
                    search_package_files_db
                    search_packages_not_installed
                    search_home_directory
                    search_system_dirs
                )
                ;;
            --aliases | -a) actions+=(search_aliases) ;;
            --builtins | -B) actions+=(search_builtins) ;;
            --command | -c) actions+=(search_loaded_commands) ;;
            --files | -F) actions+=(search_package_files_db) ;;
            --functions | -f) actions+=(search_shell_functions) ;;
            --home | -H) actions+=(search_home_directory) ;;
            --installed | -i) actions+=(search_installed_packages) ;;
            --manpages | --man) actions+=(search_manpages) ;;
            --modules | -m) actions+=(loaded_kernel_modules) ;;
            --not-installed | -n) actions+=(search_packages_not_installed) ;;
            --process | -x) actions+=(search_running_processes) ;;
            --packages | -p | --pkg) actions+=(search_package_repo) ;;
            --path | -P) actions+=(search_path) ;;
            --systemd | -s) actions+=(search_systemd_units) ;;
            --system | -R) actions+=(search_system_dirs) ;;
            --help | -h) help; return ;;
            *)
                pattern="$1"
                ;;
        esac
        shift
    done

    [ ${#actions[@]} -eq 0 ] && {
        echo "search: No criteria given"
        echo "Search: for more information try [search --help]"
        return 1
    }

    [ -z "$pattern" ] && [ "${actions[0]}" = "search_path" ] && pattern="**"

    # execute all actions and pipe combined output to less if requested
    if [ "$use_less" = true ]; then
        {
            for fn in "${actions[@]}"; do
                "$fn" "$pattern"
            done
        } | less
    else
        for fn in "${actions[@]}"; do
            "$fn" "$pattern"
        done
    fi

    footer
}
