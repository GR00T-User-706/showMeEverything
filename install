#!/usr/bin/env bash
set -e

# --- Colors for output ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# --- Detect shell and set SCRIPT_DIR ---
if [ -n "$ZSH_VERSION" ]; then
    SCRIPT_DIR="${0:A:h}"               # Zsh
elif [ -n "$BASH_VERSION" ]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"   # Bash
else
    echo -e "${RED}Unsupported shell. Only Bash and Zsh are supported.${NC}"
    exit 1
fi

# --- Check for root ---
if [[ $EUID -ne 0 ]]; then
    echo -e "${RED}Please run as root (sudo ./install.sh)${NC}"
    exit 1
fi

echo -e "${GREEN}Installing Show Me Everything...${NC}"

# --- Refresh: Attempt Qt GUI build (do not exit on failure) ---
echo -e "${YELLOW}Attempting Qt GUI build...${NC}"
cd "$SCRIPT_DIR/showmeeverything_gui"

# Clean previous build artifacts (ignore errors)
rm -f Makefile qrc_resources.cpp moc_*.cpp *.o showmeeverything_gui 2>/dev/null || true

# Build and capture status
QT_BUILD_OK=0
if qmake showmeeverything_gui.pro && make; then
    QT_BUILD_OK=1
    echo -e "${GREEN}Qt GUI built successfully${NC}"
else
    QT_BUILD_OK=0
    echo -e "${YELLOW}Qt GUI build failed (missing dependencies?), continuing...${NC}"
fi

# --- Installation (back to project root) ---
cd "$SCRIPT_DIR"

# 1. CLI search engine
echo "Installing search engine..."
install -m 755 "$SCRIPT_DIR/showMeEverything" /usr/local/bin/showMeEverything

# 2. Python/Tk GUI (fallback – works anywhere)
echo "Installing Python GUI..."
install -m 755 "$SCRIPT_DIR/showmeeverything_gui/showmeeverything_tk.py" /usr/local/bin/showmeeverything_tk.py

# 3. Qt/QML GUI (only if build succeeded)
if [ $QT_BUILD_OK -eq 1 ] && [ -f "$SCRIPT_DIR/showmeeverything_gui/showmeeverything_gui" ]; then
    echo "Installing Qt GUI..."
    install -m 755 "$SCRIPT_DIR/showmeeverything_gui/showmeeverything_gui" /usr/local/bin/showmeeverything_gui
else
    echo -e "${YELLOW}Qt GUI not built – skipping installation.${NC}"
fi

# 4. Icon
echo "Installing icon..."
install -d -m 755 /usr/local/share/icons
install -m 644 "$SCRIPT_DIR/assets/showMeEverything.png" /usr/local/share/icons/showMeEverything.png

# 5. Desktop entries
echo "Installing desktop entries..."
install -d -m 755 /usr/local/share/applications
install -m 644 "$SCRIPT_DIR/assets/showmeeverything.desktop" /usr/local/share/applications/
install -m 644 "$SCRIPT_DIR/assets/search_gui.desktop" /usr/local/share/applications/

# --- Verification ---
echo -e "${GREEN}Installation complete!${NC}"
echo ""
echo "Files installed:"
ls -la /usr/local/bin/showMeEverything
ls -la /usr/local/bin/showmeeverything_tk.py
[ -f /usr/local/bin/showmeeverything_gui ] && ls -la /usr/local/bin/showmeeverything_gui || echo "Qt GUI not installed"
ls -la /usr/local/share/icons/showMeEverything.png
ls -la /usr/local/share/applications/showmeeverything.desktop
ls -la /usr/local/share/applications/search_gui.desktop

echo ""
if [ $QT_BUILD_OK -eq 0 ]; then
    echo -e "${YELLOW}Note: Qt GUI was not built. Install Qt5/Qt6 and qml modules, then re-run this script.${NC}"
    echo -e "${YELLOW}The Python/Tk GUI (showmeeverything_tk.py) is fully functional as a fallback.${NC}"
else
    echo -e "${GREEN}All components installed. You can now launch Show Me Everything from your app launcher.${NC}"
fi